{
  email {$LETSENCRYPT_EMAIL}
}

# Set APP_DOMAIN=:80 for HTTP-only bootstrap, or a DNS hostname for automatic HTTPS.
{$APP_DOMAIN::80} {
  # Disable CloudFront Origin Secret check temporarily.
  # When the API is accessed directly by the browser (or WebSockets),
  # the custom header is missing, which causes Caddy to block all requests with 403.
  # Security is still enforced via FastAPI CORSMiddleware and Cognito JWTs.

  encode zstd gzip

  # Strip duplicate Server headers (uvicorn + Caddy) to prevent HTTP 400
  # from strict security agents that reject malformed multi-value Server headers.
  header -Server

  # SSE streaming: disable response buffering for the AI analyze endpoint
  # so that Server-Sent Events are flushed immediately to the client.
  handle /api/ai/* {
    reverse_proxy 127.0.0.1:{$PORT:8000} {
      flush_interval -1
    }
  }

  # All other routes: standard reverse proxy
  handle {
    reverse_proxy 127.0.0.1:{$PORT:8000}
  }
}
