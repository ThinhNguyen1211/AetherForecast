APP_NAME=AetherForecast Backend
APP_ENV=dev
LOG_LEVEL=INFO
PORT=8000
UVICORN_WORKERS=1
APP_DOMAIN=:80
LETSENCRYPT_EMAIL=ops@example.com

AWS_REGION=ap-southeast-1
AWS_ENDPOINT_URL=

DATA_BUCKET=aetherforecast-data-<account>-<region>
MODEL_BUCKET=aetherforecast-models-<account>-<region>
MODEL_PREFIX=chronos/models
MODEL_S3_URI=s3://aetherforecast-models-<account>-<region>/chronos-v1/model/
REQUIRE_S3_MODEL=true

HF_MODEL_FALLBACK_ID=amazon/chronos-2
HF_TOKENIZER_FALLBACK_ID=amazon/chronos-2
MODEL_CACHE_DIR=/tmp/aetherforecast-model-cache
MODEL_TORCH_DTYPE=auto
INFERENCE_NUM_SAMPLES=20

COGNITO_USER_POOL_ID=ap-southeast-1_xxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_REGION=ap-southeast-1

CORS_ORIGINS=http://localhost:5173,http://localhost:3000

SYMBOLS_SOURCE=binance
BINANCE_BASE_URL=https://api.binance.com
BINANCE_WS_URL=wss://stream.binance.com:9443
REALTIME_KLINE_INTERVAL=1m

FETCH_CONCURRENCY=32
FETCH_SYMBOL_LIMIT=0
PARQUET_PREFIX=market/klines

EXTERNAL_SENTIMENT_ENABLED=true
EXTERNAL_SENTIMENT_REFRESH_SECONDS=900
EXTERNAL_SENTIMENT_FORCE_REFRESH_PER_REQUEST=true
EXTERNAL_SENTIMENT_REQUIRE_LIVE_SOURCES=true
SENTIMENT_MODE=simple
SENTIMENT_MODEL_ID=ProsusAI/finbert
SENTIMENT_CACHE_DIR=/tmp/aetherforecast-sentiment-cache
EXTERNAL_SENTIMENT_NEWS_RSS_URLS=https://www.coindesk.com/arc/outboundfeeds/rss/,https://cointelegraph.com/rss,https://www.reuters.com/markets/currencies/rss
EXTERNAL_X_SENTIMENT_ENDPOINT=
EXTERNAL_GEOPOLITICAL_SENTIMENT_ENDPOINT=
